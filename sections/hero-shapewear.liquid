{{ 'hero-shapewear.css' | asset_url | stylesheet_tag }}
<style>
    .hero_shapewear .hero-btn{
        background: {{ section.settings.btn_bg }};
        color: {{ section.settings.btn_text }};
        border-radius: {{ section.settings.btn_radius }}px;
    }
    .hero_shapewear .hero-btn:hover{
      background: {{ section.settings.btn_hover_bg }};
      color: {{ section.settings.btn_hover_text }};
      border-color: {{ section.settings.btn_hover_border }};
    }
</style>
<section 
  class="hero hero_shapewear"
  style="
    background-color: {{ section.settings.bg_color }};
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;">

  <div class="hero__media">

    {% if section.settings.image != blank %}
      <img src="{{ section.settings.image | image_url: width: 2400 }}" width=""height="" alt="Hero Image"loading="lazy" />
    {% else %}
      {{ 'hero-apparel-1' | placeholder_svg_tag: 'placeholder-svg' }}
    {% endif %}

    <!-- OVERLAY -->
    <div 
      class="hero__overlay pos-{{ section.settings.content_position }}"
      style="background: rgba(0,0,0,{{ section.settings.overlay_opacity | divided_by: 100.0 }});"
    >

      <!-- CONTENT BOX -->
      <div 
        class="hero__content"
        style="background: {{ section.settings.content_bg }}; padding: 25px; border-radius: 12px;"
      >

        {% if section.settings.heading != blank %}
          <h2 class="mr_zero"
            style="font-size: {{ section.settings.heading_size }}px; color: {{ section.settings.heading_color }};">
            {{ section.settings.heading }}
          </h2>
        {% endif %}

        {% if section.settings.subheading != blank %}
          <p class="mr_zero"
            style="font-size: {{ section.settings.text_size }}px; color: {{ section.settings.text_color }};">
            {{ section.settings.subheading }}
          </p>
        {% endif %}

        {% if section.settings.button_label != blank %}
          <a 
            href="{{ section.settings.button_link }}" 
            class="hero-btn">
            {{ section.settings.button_label }}
          </a>
        {% endif %}

      </div>

    </div>

  </div>
</section>


{% schema %}
{
  "name": "Hero Full Shapewear",
  "class": "hero_shapewear",
  "settings": [

    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding Top",
      "min": 0,
      "max": 120,
      "step": 2,
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding Bottom",
      "min": 0,
      "max": 120,
      "step": 2,
      "default": 40
    },

    {
      "type": "image_picker",
      "id": "image",
      "label": "Hero Image"
    },

    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#ffffff"
    },

    {
      "type": "color",
      "id": "content_bg",
      "label": "Content Box Background",
      "default": "rgba(0,0,0,0.4)"
    },

    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Overlay Opacity",
      "min": 0,
      "max": 90,
      "step": 5,
      "default": 30
    },

    {
      "type": "select",
      "id": "content_position",
      "label": "Content Position",
      "default": "center",
      "options": [
        { "value": "top-left", "label": "Top Left" },
        { "value": "top-center", "label": "Top Center" },
        { "value": "top-right", "label": "Top Right" },

        { "value": "center-left", "label": "Center Left" },
        { "value": "center", "label": "Center" },
        { "value": "center-right", "label": "Center Right" },

        { "value": "bottom-left", "label": "Bottom Left" },
        { "value": "bottom-center", "label": "Bottom Center" },
        { "value": "bottom-right", "label": "Bottom Right" }
      ]
    },

    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Feel Confident Every Day"
    },
    {
      "type": "range",
      "id": "heading_size",
      "label": "Heading Size",
      "min": 20,
      "max": 80,
      "step": 1,
      "default":28
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading Color",
      "default": "#ffffff"
    },

    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Premium shapewear designed for comfort & confidence."
    },
    {
      "type": "range",
      "id": "text_size",
      "label": "Text Size",
      "min": 12,
      "max": 30,
      "step": 1,
      "default": 14
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#ffffff"
    },

    {
      "type": "text",
      "id": "button_label",
      "label": "Button Label",
      "default": "Shop Now"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    },

    {
      "type": "color",
      "id": "btn_bg",
      "label": "Button Background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "btn_text",
      "label": "Button Text",
      "default": "#000000"
    },

    {
      "type": "color",
      "id": "btn_hover_bg",
      "label": "Hover Background",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "btn_hover_text",
      "label": "Hover Text",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "btn_hover_border",
      "label": "Hover Border",
      "default": "#ffffff"
    },

    {
      "type": "range",
      "id": "btn_radius",
      "label": "Button Radius",
      "min": 0,
      "max": 50,
      "step": 1,
      "default": 8
    }

  ],
  "presets": [
    {
      "name": "Hero Full Shapewear"
    }
  ]
}
{% endschema %}