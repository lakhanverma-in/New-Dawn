.mr_zero{ margin:0;    line-height: inherit; }

.hero__media{
  position:relative;
  width:100%;
  height:600px;
  overflow:hidden;
}

.hero__media img{
  width:100%;
  height:100%;
  object-fit:cover;
  display:block;
}

.hero__overlay{
  position:absolute;
  inset:0;
  display:flex;
  padding:20px;
}

.hero_shapewear .hero__content{
  max-width:700px;
  text-align:center;
  color:#fff;
}

.hero_shapewear .hero-btn{
  display:inline-block;
  padding:15px 30px;
  margin-top:20px;
  text-decoration:none;
  transition:0.3s ease;
  line-height: normal;
}


/* POSITION SYSTEM */
.pos-center{ align-items:center; justify-content:center; }
.pos-top-left{ align-items:flex-start; justify-content:flex-start; }
.pos-top-center{ align-items:flex-start; justify-content:center; }
.pos-top-right{ align-items:flex-start; justify-content:flex-end; }

.pos-center-left{ align-items:center; justify-content:flex-start; }
.pos-center-right{ align-items:center; justify-content:flex-end; }

.pos-bottom-left{ align-items:flex-end; justify-content:flex-start; }
.pos-bottom-center{ align-items:flex-end; justify-content:center; }
.pos-bottom-right{ align-items:flex-end; justify-content:flex-end; }

@media(max-width:768px){
  .hero_shapewear .hero__media{
    height:420px;
  }
}
